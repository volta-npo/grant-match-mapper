{
  "name": "@volta-oss/grant-match-mapper",
  "version": "3.0.0",
  "private": false,
  "type": "module",
  "description": "A grant-fit workspace that maps opportunities to a small organization’s facts, constraints, and readiness.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.js",
    "start": "python3 -m http.server 4173",
    "validate": "npm test",
    "certify": "npm run build && node --test test/v3.test.js",
    "test:all": "npm test",
    "test:python": "PYTHONPATH=backend/python python3 -m unittest discover -s backend/python/tests",
    "test:backend": "npm run test:python",
    "clean": "rm -f src/*.js src/*.js.map src/*.d.ts test/*.js test/*.js.map test/*.d.ts",
    "ci": "npm ci && npm test && npm run test:backend --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docker:build": "docker build -t volta-oss/grant-match-mapper:local .",
    "docker:run": "docker compose up --build",
    "serve:python": "PYTHONPATH=backend/python python3 -m grant_match_mapper_backend.server",
    "lint": "npm run typecheck",
    "format:check": "node --check src/*.js test/*.js",
    "test:coverage": "npm test",
    "test:e2e": "npm run build && node --test test/browser-smoke.test.js",
    "test:a11y": "npm run build && node --test test/core.test.js"
  },
  "keywords": [
    "digital-equity",
    "finance-grants",
    "local-first",
    "oss",
    "release",
    "volta"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volta-npo/11-grant-match-mapper.git"
  },
  "homepage": "https://volta-npo.github.io/11-grant-match-mapper/",
  "bugs": {
    "url": "https://github.com/volta-npo/11-grant-match-mapper/issues"
  },
  "author": "Volta Open Source <volta.npo@gmail.com>",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^24.0.0"
  }
}
